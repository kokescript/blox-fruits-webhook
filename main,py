import os
import requests
import json

# GitHubの隠し部屋からURLを読み込む
WEBHOOK_URL = os.environ.get("DISCORD_WEBHOOK_URL")

def get_blox_fruits_stock():
    try:
        # 海外の信頼できる無料のブロフル在庫APIからデータを取得
        response = requests.get("https://bloxfruits.xyz", timeout=10)
        if response.status_code == 200:
            data = response.json()
            # APIのデータ構造に合わせて果物の名前リストを作成
            # ※APIの形式によって調整が必要な場合があります
            return [fruit['name'] for fruit in data.get('current', [])]
    except Exception as e:
        print(f"データ取得エラー: {e}")
    
    # 万が一APIが落ちていた場合のバックアップ（検証用）
    return ["APIからデータを取得できませんでした"]

def send_discord(stock_list):
    if not WEBHOOK_URL:
        print("エラー: DiscordのウェブフックURLが未設定です")
        return
        
    stock_text = "\n".join([f"• {fruit}" for fruit in stock_list])
    
    payload = {
        "username": "ブロフル入荷Bot",
        "embeds": [{
            "title": "🏪 現在のフルーツディーラー在庫",
            "description": f"【現在のラインナップ】\n\n{stock_text}\n\n※4時間ごとに自動更新中",
            "color": 16753920
        }]
    }
    
    res = requests.post(WEBHOOK_URL, data=json.dumps(payload), headers={"Content-Type": "application/json"})
    if res.status_code != 204:
        print(f"Discord送信エラー: {res.status_code}")

if __name__ == "__main__":
    fruits = get_blox_fruits_stock()
    send_discord(fruits)
