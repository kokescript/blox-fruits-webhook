import os
import requests
import json

# GitHubの設定からDiscordのURLを読み込む
WEBHOOK_URL = os.environ.get("DISCORD_WEBHOOK_URL")

def get_blox_fruits_stock():
    try:
        # 【修正】正しいAPIのURLに書き換えました
        response = requests.get("https://bloxfruits.xyz", timeout=5)
        if response.status_code == 200:
            data = response.json()
            # APIから現在のショップの果物名リストを抽出
            fruits = [fruit['name'] for fruit in data.get('current', [])]
            if fruits:
                return fruits
    except Exception as e:
        print(f"APIエラー: {e}")
    
    # APIからデータが取れなかった場合のバックアップ
    return ["現在ショップ情報を読み込み中です。しばらくお待ちください。"]

def send_discord(stock_list):
    if not WEBHOOK_URL:
        print("エラー: DiscordのウェブフックURLが設定されていません")
        return
        
    stock_text = "\n".join([f"• {fruit}" for fruit in stock_list])
    
    payload = {
        "username": "ブロフル入荷Bot",
        "embeds": [{
            "title": "🏪 現在のフルーツディーラー在庫",
            "description": f"【現在のラインナップ】\n\n{stock_text}\n\n※4時間ごとに自動更新中",
            "color": 16753920
        }]
    }
    
    # Discordへデータを送信
    res = requests.post(WEBHOOK_URL, data=json.dumps(payload), headers={"Content-Type": "application/json"})
    if res.status_code == 204:
        print("Discordへの通知に成功しました！")
    else:
        print(f"Discord送信失敗: {res.status_code}")

if __name__ == "__main__":
    fruits = get_blox_fruits_stock()
    send_discord(fruits)
