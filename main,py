import os
import requests
import json
from bs4 import BeautifulSoup

WEBHOOK_URL = os.environ.get("DISCORD_WEBHOOK_URL")

def get_real_blox_fruits_stock():
    try:
        # ブロフル公式Wikiのストックページからデータを取得
        url = "https://fandom.com"
        headers = {"User-Agent": "Mozilla/5.0"}
        response = requests.get(url, headers=headers, timeout=10)
        
        if response.status_code == 200:
            soup = BeautifulSoup(response.text, 'html.parser')
            
            # Wikiのページ内から「Current Stock（現在の在庫）」のテーブルを探す
            # ページ構造から果物の名前が入っている要素を抽出します
            fruits = []
            # 現在のストックが表示されているテーブルの枠を探す（一般的なFandomの構成）
            stock_table = soup.find('table', {'class': 'article-table'})
            if stock_table:
                rows = stock_table.find_all('tr')
                for row in rows[1:]: # 見出しを飛ばす
                    cols = row.find_all('td')
                    if cols:
                        fruit_name = cols[0].text.strip()
                        fruits.append(fruit_name)
            
            if fruits:
                return fruits
                
    except Exception as e:
        print(f"Wikiからのデータ取得に失敗しました: {e}")
        
    return ["データの自動取得に失敗しました。Wikiのページ構成が変わった可能性があります。"]

def send_discord(stock_list):
    if not WEBHOOK_URL:
        print("エラー: DiscordのウェブフックURLが未設定です")
        return
        
    stock_text = "\n".join([f"• {fruit}" for fruit in stock_list])
    
    payload = {
        "username": "ブロフル入荷Bot",
        "embeds": [{
            "title": "🏪 現在のフルーツディーラーリアルタイム在庫",
            "description": f"【現在の公式ラインナップ】\n\n{stock_text}\n\n※4時間ごとにWikiから最新情報を自動取得中",
            "color": 16753920
        }]
    }
    
    requests.post(WEBHOOK_URL, data=json.dumps(payload), headers={"Content-Type": "application/json"})

if __name__ == "__main__":
    fruits = get_real_blox_fruits_stock()
    send_discord(fruits)
